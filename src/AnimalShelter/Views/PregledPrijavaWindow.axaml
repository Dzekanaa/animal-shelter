<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AnimalShelter.ViewModels"
        x:Class="AnimalShelter.Views.PregledPrijavaWindow"
        Title="Pregled prijava za volontiranje"
        Width="700" Height="400"
        WindowStartupLocation="CenterOwner"
        x:DataType="vm:PregledPrijavaViewModel">
    <Design.DataContext>
        <vm:PregledPrijavaViewModel />
    </Design.DataContext>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <Button Command="{Binding PrihvatiCommand}" Content="Prihvati" Margin="0,0,5,0"/>
            <Button Command="{Binding OdbijCommand}" Content="Odbij" Margin="0,0,5,0"/>
            <Button Command="{Binding OsveziCommand}" Content="Osveži" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Prijave}"
                  SelectedItem="{Binding SelectedPrijava}"
                  AutoGenerateColumns="False"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Ime" Binding="{Binding Ime}" Width="100"/>
                <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}" Width="100"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusPrijave}" Width="100"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding DatumPodnosenja, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>