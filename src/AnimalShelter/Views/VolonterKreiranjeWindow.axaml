<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AnimalShelter.ViewModels"
        x:Class="AnimalShelter.Views.VolonterKreiranjeWindow"
        Title="Kreiranje volontera"
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
        x:DataType="vm:VolonterKreiranjeViewModel">
    <Design.DataContext>
        <vm:VolonterKreiranjeViewModel />
    </Design.DataContext>

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Kreiraj" Click="OnKreirajClick" Margin="0,0,5,0"/>
            <Button Content="Odustani" Click="OnOdustaniClick"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Korisničko ime*" Margin="0,5,0,0"/>
            <TextBox Text="{Binding KorisnickoIme}" Margin="0,0,0,5"/>
            <TextBlock Text="Lozinka*" Margin="0,5,0,0"/>
            <TextBox Text="{Binding Lozinka}" PasswordChar="*" Margin="0,0,0,5"/>
            <TextBlock Text="Potvrdi lozinku*" Margin="0,5,0,0"/>
            <TextBox Text="{Binding LozinkaPotvrda}" PasswordChar="*" Margin="0,0,0,5"/>
        </StackPanel>
    </DockPanel>
</Window>