<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AnimalShelter.ViewModels"
             xmlns:models="clr-namespace:AnimalShelter.Models"
             x:Class="AnimalShelter.Views.UdruzenjaView"
             x:DataType="vm:UdruzenjaViewModel">
    <Design.DataContext>
        <vm:UdruzenjaViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <Button Command="{Binding DodajCommand}" IsEnabled="{Binding CanManageUdruzenja}" Content="Dodaj" Margin="0,0,5,0"/>
            <Button Command="{Binding IzmeniCommand}" IsEnabled="{Binding CanManageUdruzenja}" Content="Izmeni" Margin="0,0,5,0"/>
            <Button Command="{Binding ObrisiCommand}" IsEnabled="{Binding CanManageUdruzenja}" Content="Obriši" Margin="0,0,5,0"/>
            <Button Command="{Binding OsveziCommand}" IsEnabled="{Binding CanManageUdruzenja}" Content="Osveži" />
            <Button Command="{Binding PregledPrijavaCommand}" 
                    Content="Pregled prijava" 
                    IsEnabled="{Binding isUdruzenjeAdmin}"
                    Margin="0,0,5,0"/>
            <Button Command="{Binding PrikaziUdomiteljeCommand}" 
                    Content="Prikaži udomitelje" 
                    Margin="0,0,5,0"/>
        </StackPanel>

        <!-- Lista -->
        <DataGrid ItemsSource="{Binding Udruzenja}"
                  SelectedItem="{Binding SelectedUdruzenje}"
                  AutoGenerateColumns="False"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
                <DataGridTextColumn Header="Datum osnivanja" Binding="{Binding DatumOsnivanja, StringFormat='dd.MM.yyyy'}" Width="120"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTemplateColumn Header="Akcija" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Udruzenje">
                            <Button Content="Životinje" 
                                    Command="{Binding $parent[DataGrid].((vm:UdruzenjaViewModel)DataContext).PrikaziZivotinjeCommand}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>