<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AnimalShelter.ViewModels"
        x:Class="AnimalShelter.Views.SviKorisniciWindow"
        Title="Svi korisnici sistema"
        Width="900" Height="500"
        WindowStartupLocation="CenterOwner"
        x:DataType="vm:SviKorisniciViewModel">
    <Design.DataContext>
        <vm:SviKorisniciViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Traka sa pretragom i dugmadima -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <Button Command="{Binding OsveziCommand}" Content="Osveži" />
        </StackPanel>

        <!-- DataGrid sa svim korisnicima -->
        <DataGrid ItemsSource="{Binding Korisnici}"
                  AutoGenerateColumns="False"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Tip" Binding="{Binding TipKorisnika}" Width="120"/>
                <DataGridTextColumn Header="Korisničko ime" Binding="{Binding KorisnickoIme}" Width="120"/>
                <DataGridTextColumn Header="Ime" Binding="{Binding Ime}" Width="100"/>
                <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}" Width="100"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="100"/>
                <DataGridTextColumn Header="Datum registracije" Binding="{Binding DatumRegistracije, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                <DataGridTextColumn Header="Udruženje ID" Binding="{Binding UdruzenjeId}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>