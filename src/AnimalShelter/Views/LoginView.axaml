<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AnimalShelter.ViewModels"
             x:Class="AnimalShelter.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Width="400" Height="300">
    <Design.DataContext>
        <vm:LoginViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*"
          HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
        
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Prijava na sistem" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Korisničko ime:" 
                   VerticalAlignment="Center" Margin="0,0,10,5"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Username}" 
                 Width="200" Margin="0,0,0,5" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Lozinka:" 
                   VerticalAlignment="Center" Margin="0,0,10,5"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Password}" 
                 Width="200" Margin="0,0,0,5" PasswordChar="*" />

        <!-- Poruka o grešci – vidljiva samo ako nije prazna -->
        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding ErrorMessage}" 
                   Foreground="Red" HorizontalAlignment="Center" Margin="0,5,0,5"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <!-- IsEnabled sada koristi svojstvo CanLogin -->
            <Button Content="Prijava" Command="{Binding LoginCommand}" 
                    IsEnabled="{Binding CanLogin}" Margin="0,0,10,0" Width="100"/>
            <Button Content="Odustani" Command="{Binding OdustaniCommand}" Width="100"/>
        </StackPanel>
    </Grid>
</UserControl>