' Opšte
'=========================

usecase "Prijava" as UC1
usecase "Odjava" as UC2
usecase "Pregled svih\nudruženja" as UC3
usecase "Pregled dostupnih\nživotinja" as UC4

usecase "Zahtev za\nvolontiranje" as UC5
usecase "Zahtev za\nudomljavanje" as UC6

usecase "Vrati\nživotinju" as UC7

'=========================
' Sistemski administrator
'=========================

usecase "<<CRUD>>\nRegistracija udruženja" as UC8
usecase "<<CRUD>>\nRegistracija\nadministratora\nudruženja" as UC9
usecase "Pregled svih\nkorisnika" as UC10

'=========================
' Administrator udruženja
'=========================

usecase "<<CRUD>>\nRegistracija\nvolontera" as UC11

usecase "Prihvatanje\nzahteva za\nvolontiranje" as UC12
usecase "Odbijanje\nzahteva za\nvolontiranje" as UC13

usecase "Promocija\nvolontera" as UC14
usecase "Pregled svih\nvolontera udruženja" as UC15

usecase "Upravljanje\ndonacijama" as UC16

usecase "Izveštaj o\nudomljavanjima" as UC17
