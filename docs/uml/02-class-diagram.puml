@startuml animal-shelter-class-diagram
!define ABSTRACT_COLOR #FFE5B4
!define ENTITY_COLOR #B4D7FF
!define VALUE_COLOR #D7FFB4

skinparam classBackgroundColor<<abstract>> ABSTRACT_COLOR
skinparam classBackgroundColor<<entity>> ENTITY_COLOR
skinparam classBackgroundColor<<value>> VALUE_COLOR
skinparam linetype ortho

' ===== ABSTRACT CLASSES =====
abstract class Korisnik <<abstract>> {
    - id: int
    - ime: string
    - prezime: string
    - email: string
    - telefon: string
    - adresa: string
    - datumRegistracije: DateTime
    + getKorisnikTip(): string
}

' ===== USER TYPES =====
class SistemanskiAdmin {
    + registrujUdruzenje(udruženje): void
    + registrujAdmina(admin): void
    + pregled(): List<Korisnik>
}

class AdminUdruzenja {
    - udruženje: Udruženje
    + promovisiVolontera(volonter): void
    + upravljajDonacijama(donacija): void
    + generirajIzveštaj(tip): Izveštaj
    + pregledVolontera(): List<Volonter>
    + pregledUdomitelja(): List<Udomitelj>
    + pregledZivotinja(): List<Životinja>
}

class Volonter {
    - udruženje: Udruženje
    - datumUclanjena: DateTime
    + dodajZivotinju(životinja): void
    + uzimiZivotinjuUSmeštaj(životinja): void
    + dodajUdomitelja(udomitelj): void
    + prihvatiZahtev(zahtev): void
    + odbijZahtev(zahtev): void
    + poveziZivotinjuSaUdomiteljem(životinja, udomitelj): void
    + dodajNapomenu(udomljavanje, napomena): void
}

class Udomitelj {
    - registrovan: boolean
    - kontaktPodaci: KontaktPodaci
    + uzimiZivotinju(životinja): void
    + vratiZivotinju(životinja): void
    + odustaniOdUdomljavanja(udomljavanje): void
}

class NeregistrovaniKorisnik {
    - kontaktPodaci: KontaktPodaci
    + pregledZivotinja(): List<Životinja>
    + pregledUdruzenja(): List<Udruženje>
    + posaljiZahtevZaUdomljavanje(zahtev): void
}

' ===== CORE ENTITIES =====
class Udruženje <<entity>> {
    - id: int
    - naziv: string
    - opis: string
    - email: string
    - telefon: string
    - adresa: string
    - datumOsnivanja: DateTime
    - racun: Racun
    + dodajVolontera(volonter): void
    + ukloniVolontera(volonter): void
}

class Životinja <<entity>> {
    - id: int
    - naziv: string
    - kategorija: KategorijiaZivotinje
    - starost: int
    - pol: string
    - rasa: string
    - vrsta: string
    - zdravstvenoStanje: string
    - opis: string
    - status: StatusZivotinje
    - slike: List<string>
    - video: List<string>
    - datumUnosa: DateTime
    + promeniStatus(noviStatus): void
    + dodajSliku(slika): void
}

enum KategorijiaZivotinje {
    PSI
    MAČKE
    ZEČEVI
    PTICE
    OSTALO
}

enum StatusZivotinje {
    DOSTUPNA
    ZAUZETA
    UDOMLJENA
}

class Udomljavanje <<entity>> {
    - id: int
    - životinja: Životinja
    - udomitelj: Udomitelj
    - datumUdomljavanja: DateTime
    - napomena: string
    - statusKomunikacije: StatusKomunikacije
    + posaljiObaveštenje(): void
    + promeniStatus(noviStatus): void
}

enum StatusKomunikacije {
    SMS
    EMAIL
    RUČNO
}

' ===== REQUEST/DEMAND =====
class ZahtevZaUdomljavanje <<entity>> {
    - id: int
    - životinja: Životinja
    - udomitelj: Udomitelj
    - datumPodnoša: DateTime
    - kontaktPodaci: KontaktPodaci
    - status: StatusZahteva
    + prihvati(): void
    + odbij(): void
}

enum StatusZahteva {
    ČEKAJUĆI
    PRIHVAĆEN
    ODBIJEN
}

' ===== DONATIONS & REPORTS =====
class Donacija <<entity>> {
    - id: int
    - vrsta: VrstaDonacije
    - iznos: decimal
    - datumUplate: DateTime
    - donator: string
    - svrha: string
    - živinjaNamena: Životinja [0..1]
    - racun: Racun
    + dodajUEvidenciju(): void
}

enum VrstaDonacije {
    HRANA
    VODA
    LEKOVI
    OPREMA
    NOVAC
}

class Izveštaj <<value>> {
    - id: int
    - tip: TipIzveštaja
    - datumGenisanja: DateTime
    - Period: Period
    - statistika: Statistika
    + generiši(): void
    + objavi(): void
}

enum TipIzveštaja {
    UDOMLJAVANJE
    DONACIJA
    DNEVNI
    NEDELNI
    MESEČNI
}

class Statistika {
    - brojUdomljenih: int
    - brojVratenih: int
    - ukupnaDonacija: decimal
    - vrsteDonaracija: List<VrstaDonacije>
}

' ===== VALUE OBJECTS =====
class KontaktPodaci <<value>> {
    - telefon: string
    - email: string
    - adresa: string
}

class Period <<value>> {
    - pocetakPerioda: DateTime
    - krajPerioda: DateTime
}

class Racun <<value>> {
    - brojRacuna: string
    - banka: string
    - stanje: decimal
    - listaUplata: List<Donacija>
}

' ===== RELATIONSHIPS =====

' Nasledjivanje
Korisnik <|-- SistemanskiAdmin
Korisnik <|-- AdminUdruzenja
Korisnik <|-- Volonter
Korisnik <|-- Udomitelj
Korisnik <|-- NeregistrovaniKorisnik

' Životinja - Status & Kategorija
Životinja --> StatusZivotinje : koristi
Životinja --> KategorijiaZivotinje : pripada

' Udruženje - Životinje
Udruženje "1" --> "*" Životinja : sadrži
Udruženje "1" --> "*" Volonter : zapošljava
Udruženje "1" --> "*" AdminUdruzenja : upravlja
Udruženje "1" --> "1" Racun : ima

' AdminUdruzenja - Udruženje
AdminUdruzenja --> Udruženje : upravlja

' Volonter - Udruženje
Volonter --> Udruženje : radi_za

' Udomljavanje
Udomljavanje --> Životinja : udomljava
Udomljavanje --> Udomitelj : kome
Udomljavanje --> StatusKomunikacije : koristi
Udomljavanje --> Volonter : pravi_volonter

' Zahtev
ZahtevZaUdomljavanje --> Životinja : za
ZahtevZaUdomljavanje --> Udomitelj : od
ZahtevZaUdomljavanje --> KontaktPodaci : sa
ZahtevZaUdomljavanje --> StatusZahteva : ima_status

' Donacija
Donacija --> VrstaDonacije : je_tipa
Donacija --> Racun : uplaćena_na
Donacija "0..1" --> "1" Životinja : namenjena

' Izveštaj
Izveštaj --> TipIzveštaja : je_tipa
Izveštaj --> Period : za_period
Izveštaj --> Statistika : sadrži
Izveštaj --> Udomljavanje : analizu
Izveštaj --> Donacija : analizu

' Udomitelj - Udomljavanje
Udomitelj "1" --> "*" Udomljavanje : ima

' KontaktPodaci
NeregistrovaniKorisnik --> KontaktPodaci : sadrži
Udomitelj --> KontaktPodaci : sadrži

note right of Životinja
  Status se menja tokom životnog ciklusa:
  DOSTUPNA -> ZAUZETA -> UDOMLJENA
  ili DOSTUPNA -> ZAUZETA -> DOSTUPNA (vraćena)
end note

note right of AdminUdruzenja
  Samo administrator može:
  - Upravljati donacijama
  - Generisati izveštaje
  - Pregledati sve korisnike
end note

note right of Donacija
  Donacija može biti:
  - Opšta (živinja = NULL)
  - Namenjena konkretnoj životinji
end note

note right of Volonter
  Volonter može biti promovisan
  u AdminUdruzenja od strane
  AdminUdruzenja
end note

@enduml
